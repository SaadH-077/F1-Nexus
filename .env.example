# ── Copy this to .env at the repo root ──────────────────────────────────────
# docker-compose reads this automatically.

# Backend API URL baked into the Next.js frontend build
NEXT_PUBLIC_API_URL=http://localhost:8000

# Ollama model (must be pulled: docker exec f1-nexus-ollama ollama pull llama3.2)
OLLAMA_MODEL=llama3.2

# SMTP — email session reminders (leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=F1 Nexus

# Public URL shown in reminder email CTA button
APP_URL=http://localhost:3000
