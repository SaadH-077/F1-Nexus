# ── Copy this to .env at the repo root ──────────────────────────────────────
# docker-compose reads this automatically.

# Backend API URL baked into the Next.js frontend build
NEXT_PUBLIC_API_URL=http://localhost:8000

# Ollama model (must be pulled: docker exec f1-nexus-ollama ollama pull llama3.2)
OLLAMA_MODEL=llama3.2

# Optional Postgres connection string (leave blank to use the SQLite volume)
DATABASE_URL=

# Email session reminders via Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=F1 Nexus <onboarding@resend.dev>

# Public URL shown in reminder email CTA button
APP_URL=http://localhost:3000
