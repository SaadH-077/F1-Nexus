# Copy this to .env and fill in your values
# The backend reads these automatically via pydantic-settings

# ── SMTP (email reminders) ─────────────────────────────────────────────────
# Gmail: enable 2FA → generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=F1 Nexus

# ── App public URL (shown in reminder email CTA) ───────────────────────────
APP_URL=https://your-deployed-app.com
