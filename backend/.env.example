# Copy this to .env and fill in your values.
# The backend reads these automatically via pydantic-settings (config.py).
# In production (Render), set these in the dashboard / render.yaml instead.

# ── Database ────────────────────────────────────────────────────────────────
# Leave blank for local SQLite (./f1nexus.db). Set to a Postgres URL in
# production for persistent storage. Render injects this automatically.
DATABASE_URL=

# ── Email reminders (Resend) ────────────────────────────────────────────────
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Must be a Resend-verified domain. Use onboarding@resend.dev for dev/testing.
RESEND_FROM_EMAIL=F1 Nexus <onboarding@resend.dev>

# ── AI Analyst (Ollama) ─────────────────────────────────────────────────────
# Set USE_OLLAMA=false to skip the LLM and use the built-in rule-based writer
# (recommended for cloud hosts with no Ollama server, e.g. Render).
USE_OLLAMA=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── App public URL (shown in reminder email CTA) ────────────────────────────
APP_URL=http://localhost:3000
